rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isPlayerInGame(gameData) {
      return isAuthenticated() && (request.auth.uid == gameData.player1Id || request.auth.uid == gameData.player2Id);
    }

    function isValidGame(data) {
      return data.stones is list && data.stones.size() == 12 &&
             data.scores is list && data.scores.size() == 2 &&
             data.currentPlayer in [0, 1] &&
             data.status is string &&
             data.updatedAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /games/{gameId} {
      // Public access for 'no-login' multiplayer
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId;
    }
  }
}
